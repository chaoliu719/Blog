---

{
  Object.entries(SITE.social).map(([platform, url]) => (
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={platform}
      class="text-muted-foreground hover:text-primary transition-all no-underline"
    >
      {icons[platform] ? (
        <svg
          role="img"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
          width={icons[platform].width ?? 16}
          height={icons[platform].height ?? 16}
          preserveAspectRatio={icons[platform].preserveAspectRatio ?? 'xMidYMid meet'}
          fill="currentColor"
        >
          <path d={icons[platform].path} />
        </svg>
      ) : (
        <span class="text-xs font-bold uppercase tracking-widest">{platform}</span>
      )}
    </a>
  ))
}
